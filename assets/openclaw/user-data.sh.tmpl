#!/bin/bash
# user-data for the OpenClawStack EC2 instance.
#
# Template: openclaw_stack.py substitutes `@@`-delimited placeholders with
# CDK-side values (paths, asset URIs, CFN-token refs for the EFS id /
# bot asset bucket / etc) before passing the rendered text to
# `ec2.UserData.custom()`. Bash uses `$VAR` / `${VAR}`; we don't.
#
# This script runs once on first boot. Cloud-init logs to
# /var/log/user-data.log; tail there to debug failures.

exec > >(tee /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1
set -euxo pipefail
trap 'echo USERDATA FAILED on line $LINENO' ERR
export DEBIAN_FRONTEND=noninteractive

# Nodesource apt repo so we install a current Node.
install -d -m 0755 /etc/apt/keyrings
curl -fsSL '@@NODESOURCE_KEY_URI@@' | gpg --dearmor -o '@@NODESOURCE_KEY_PATH@@'
echo "deb [signed-by=@@NODESOURCE_KEY_PATH@@] @@NODESOURCE_REPO_URI@@ nodistro main" >'@@NODESOURCE_REPO_PATH@@'
apt-get update
apt-get install -y @@BUILD_DEPENDENCIES@@

# Enable service lingering so the openclaw + matrix-bot user units
# can run without a login shell.
loginctl enable-linger ubuntu

# Mount EFS at the well-known mountpoint.
curl -fsSL '@@EFS_UTILS_INSTALLER_URI@@' | sh -s -- --install
mkdir -p '@@EFS_MOUNTPOINT_DIR@@'
echo "@@EFS_FSTAB@@" >>/etc/fstab
mount -a
mountpoint -q '@@EFS_MOUNTPOINT_DIR@@'

# Install OpenClaw globally from npm. State + workspaces live on EFS.
mkdir -p '@@OPENCLAW_HOME_DIR@@' '@@OPENCLAW_STATE_DIR@@' '@@OPENCLAW_WORKSPACES_DIR@@'
chown -R ubuntu:ubuntu '@@OPENCLAW_HOME_DIR@@' '@@OPENCLAW_STATE_DIR@@' '@@OPENCLAW_WORKSPACES_DIR@@'
npm install -g openclaw@latest
cat >/etc/profile.d/openclaw.sh <<'EOF'
export OPENCLAW_HOME=@@OPENCLAW_HOME_DIR@@
export OPENCLAW_STATE_DIR=@@OPENCLAW_STATE_DIR@@
EOF
chmod 0644 /etc/profile.d/openclaw.sh

# Install Homebrew as ssm-user (Homebrew refuses to run as root but
# does need sudo). ssm-user is normally created lazily on first
# SSM session; pre-create it.
id ssm-user >/dev/null 2>&1 || useradd -m -s /bin/bash ssm-user
install -d -m 0755 /etc/sudoers.d
echo "ssm-user ALL=(ALL) NOPASSWD:ALL" >/etc/sudoers.d/ssm-user
curl -fsSL '@@HOMEBREW_INSTALLER_URI@@' | sudo -iu ssm-user /bin/bash
sudo -u ssm-user /home/linuxbrew/.linuxbrew/bin/brew shellenv | tee /etc/profile.d/homebrew.sh >/dev/null
chmod 0644 /etc/profile.d/homebrew.sh

# Install pnpm at a pinned version (see openclaw_stack.PNPM_VERSION
# for why; v11 broke the matrix-sdk-crypto-nodejs install path).
curl -fsSL '@@PNPM_INSTALLER_URI@@' | sudo -iu ubuntu env PNPM_VERSION='@@PNPM_VERSION@@' /bin/bash

# Onboard openclaw + enable hooks. `sudo -i` + XDG_RUNTIME_DIR
# together let systemctl manage user units without a login cycle.
sudo -iu ubuntu XDG_RUNTIME_DIR="/run/user/$(id -u ubuntu)" \
  openclaw onboard \
  --non-interactive --accept-risk \
  --mode local --tailscale serve \
  --install-daemon --gateway-auth token --gateway-bind loopback \
  --daemon-runtime node --node-manager pnpm \
  --workspace '@@OPENCLAW_MAIN_WORKSPACE@@' \
  --auth-choice skip --skip-channels --skip-search --skip-skills \
  --json
@@OPENCLAW_HOOK_COMMANDS@@

# Matrix bot install. The bot source bundle is uploaded as an S3
# asset by CDK; fetch it, unzip into /opt, build on the host (so
# node_modules + dist stay out of the asset zip). E2E + sync state
# lives under /data/matrix-bot on EFS so device verification
# persists across instance replacements.
apt-get install -y unzip python3
curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscliv2.zip
unzip -oq /tmp/awscliv2.zip -d /tmp
/tmp/aws/install --update
mkdir -p '@@MATRIX_BOT_INSTALL_DIR@@' '@@MATRIX_BOT_DIR@@'
chown -R ubuntu:ubuntu '@@MATRIX_BOT_DIR@@'
aws s3 cp '@@BOT_ASSET_S3_URI@@' /tmp/openclaw_bot.zip
unzip -oq /tmp/openclaw_bot.zip -d '@@MATRIX_BOT_INSTALL_DIR@@'
chown -R ubuntu:ubuntu '@@MATRIX_BOT_INSTALL_DIR@@'
chmod +x '@@MATRIX_BOT_INSTALL_DIR@@/scripts/prestart'
# pnpm v10's installer puts the shim at ~/.local/share/pnpm/pnpm
# directly (no bin/ subdir, unlike v11). matrix-sdk-crypto-nodejs's
# postinstall would normally download a platform-specific .node
# binding; under pnpm v11 + --frozen-lockfile + --ignore-scripts we
# can't trigger postinstalls automatically, so run the downloader by
# hand right after install. Using `tsc` directly instead of `pnpm
# run build` -- pnpm run does an extra dep-status round-trip that
# crashes against the readonly node_modules layout pnpm leaves on
# disk in some configurations.
sudo -iu ubuntu CI=true bash -c "cd '@@MATRIX_BOT_INSTALL_DIR@@' && ~/.local/share/pnpm/pnpm install --frozen-lockfile --ignore-scripts && (cd node_modules/@matrix-org/matrix-sdk-crypto-nodejs && node download-lib.js) && ./node_modules/.bin/tsc"

# Drop a systemd user unit that runs the bot as ubuntu.
install -d -m 0755 /home/ubuntu/.config/systemd/user
cat >/home/ubuntu/.config/systemd/user/openclaw-matrix-bot.service <<EOF
[Unit]
Description=OpenClaw Matrix bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@@MATRIX_BOT_INSTALL_DIR@@
RuntimeDirectory=openclaw-matrix-bot
RuntimeDirectoryMode=0700
Environment=HOMESERVER_URL=@@HOMESERVER_URL@@
Environment=ALLOWED_SENDER=@@ALLOWED_SENDER@@
Environment=MATRIX_BOT_DATA_DIR=@@MATRIX_BOT_DIR@@
Environment=OPENCLAW_GATEWAY_TOKEN_FILE=%t/openclaw-matrix-bot/gateway-token
Environment=BOT_ACCESS_TOKEN_FILE=%t/openclaw-matrix-bot/access-token
Environment=BOT_TOKEN_SECRET_ID=@@MATRIX_BOT_TOKEN_SECRET@@
Environment=CONTROL_ROOM_PARAM=@@MATRIX_BOT_CONTROL_ROOM_PARAM@@
Environment=OPENCLAW_STATE_FILE=@@OPENCLAW_STATE_FILE@@
EnvironmentFile=-%t/openclaw-matrix-bot/env
ExecStartPre=@@MATRIX_BOT_INSTALL_DIR@@/scripts/prestart
ExecStart=/usr/bin/node @@MATRIX_BOT_INSTALL_DIR@@/dist/index.js
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
EOF
chown ubuntu:ubuntu /home/ubuntu/.config/systemd/user/openclaw-matrix-bot.service
chmod 0644 /home/ubuntu/.config/systemd/user/openclaw-matrix-bot.service

# Enable + start. Failure to start on first deploy (before the
# control-room SSM param exists) is expected; `restart` after
# populating the param is the manual recovery.
sudo -iu ubuntu XDG_RUNTIME_DIR="/run/user/$(id -u ubuntu)" systemctl --user daemon-reload
sudo -iu ubuntu XDG_RUNTIME_DIR="/run/user/$(id -u ubuntu)" systemctl --user enable --now openclaw-matrix-bot.service

# Matrix Application Service install. Same package-build dance as
# the bot above; uses its own asset bundle. systemd user unit runs
# alongside the bot during Phase B so the existing @openclaw-bot
# stays usable while we evaluate the AS approach.
mkdir -p '@@AS_INSTALL_DIR@@'
aws s3 cp '@@AS_ASSET_S3_URI@@' /tmp/openclaw_appservice.zip
unzip -oq /tmp/openclaw_appservice.zip -d '@@AS_INSTALL_DIR@@'
chown -R ubuntu:ubuntu '@@AS_INSTALL_DIR@@'
chmod +x '@@AS_INSTALL_DIR@@/scripts/prestart'
sudo -iu ubuntu CI=true bash -c "cd '@@AS_INSTALL_DIR@@' && ~/.local/share/pnpm/pnpm install --frozen-lockfile --ignore-scripts && (cd node_modules/@matrix-org/matrix-sdk-crypto-nodejs && node download-lib.js) && ./node_modules/.bin/tsc"

cat >/home/ubuntu/.config/systemd/user/openclaw-matrix-appservice.service <<EOF
[Unit]
Description=OpenClaw Matrix Application Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@@AS_INSTALL_DIR@@
RuntimeDirectory=openclaw-matrix-appservice
RuntimeDirectoryMode=0700
Environment=HOMESERVER_URL=@@HOMESERVER_URL@@
Environment=HOMESERVER_NAME=@@HOMESERVER_NAME@@
Environment=ALLOWED_SENDER=@@ALLOWED_SENDER@@
Environment=AGENT_IDS=@@AGENT_IDS@@
Environment=AS_PORT=@@AS_PORT@@
Environment=AS_PUBLIC_URL=@@AS_PUBLIC_URL@@
Environment=APPSERVICE_AS_TOKEN_SECRET_ID=@@APPSERVICE_AS_TOKEN_SECRET_ID@@
Environment=APPSERVICE_HS_TOKEN_SECRET_ID=@@APPSERVICE_HS_TOKEN_SECRET_ID@@
Environment=APPSERVICE_AS_TOKEN_FILE=%t/openclaw-matrix-appservice/as-token
Environment=APPSERVICE_HS_TOKEN_FILE=%t/openclaw-matrix-appservice/hs-token
Environment=OPENCLAW_GATEWAY_TOKEN_FILE=%t/openclaw-matrix-appservice/gateway-token
Environment=OPENCLAW_STATE_FILE=@@OPENCLAW_STATE_FILE@@
ExecStartPre=@@AS_INSTALL_DIR@@/scripts/prestart
ExecStart=/usr/bin/node @@AS_INSTALL_DIR@@/dist/index.js
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
EOF
chown ubuntu:ubuntu /home/ubuntu/.config/systemd/user/openclaw-matrix-appservice.service
chmod 0644 /home/ubuntu/.config/systemd/user/openclaw-matrix-appservice.service

sudo -iu ubuntu XDG_RUNTIME_DIR="/run/user/$(id -u ubuntu)" systemctl --user daemon-reload
sudo -iu ubuntu XDG_RUNTIME_DIR="/run/user/$(id -u ubuntu)" systemctl --user enable --now openclaw-matrix-appservice.service
