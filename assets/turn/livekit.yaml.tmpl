# LiveKit server config rendered on-host by turn user-data.
# Placeholders of the form __KEY__ are substituted at boot
# (after Python's @@KEY@@ pass on the wrapping shell script).
#
# LiveKit has no native TLS option; user-data installs an nginx
# reverse-proxy that terminates TLS on 443 and forwards to
# 127.0.0.1:7880. Clients connect via `wss://livekit.<domain>`
# (default port 443) -- the :7880 backend port stays internal.

port: 7880

bind_addresses:
  - "127.0.0.1"

rtc:
  tcp_port: 7881
  udp_port: 7882
  use_external_ip: true

keys:
  # `key: secret` pairs used to sign + verify the JWTs that
  # lk-jwt-service mints for Element-Call clients.
  "__LIVEKIT_API_KEY__": "__LIVEKIT_API_SECRET__"

logging:
  level: info
  json: false
