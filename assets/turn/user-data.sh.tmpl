#!/bin/bash
# user-data for the TurnStack EC2 instance.
#
# Co-locates coturn (RFC5766 TURN/STUN server) and livekit-server
# (Element-Call SFU) on a single host with one Elastic IP and one
# multi-SAN TLS cert. Layout:
#
#   coturn         3478/udp+tcp (STUN/TURN), 5349/tcp (TURN-TLS),
#                  49152-49251/udp (relay range)
#   livekit-server 7880/tcp (signaling WSS), 7881/tcp (RTC TCP),
#                  7882/udp (RTC UDP)
#
# certbot owns the cert (DNS-01 via Route53). Renewal cron runs
# daily; deploy-hook re-permissions the cert + reloads both
# services.
#
# Template: turn_stack.py substitutes `@@KEY@@` placeholders for
# CDK-side values BEFORE this script lands on the host.
# turnserver.conf.tmpl + livekit.yaml.tmpl use `__KEY__` for the
# host-side render() step so the two layers don't collide.
# Bash uses `$VAR` / `${VAR}`. Logs to /var/log/user-data.log.

exec > >(tee /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1
set -euxo pipefail
trap 'echo USERDATA FAILED on line $LINENO' ERR
export DEBIAN_FRONTEND=noninteractive

apt-get update
apt-get install -y \
  certbot \
  python3-certbot-dns-route53 \
  coturn \
  curl \
  jq \
  nginx \
  unzip

# Ubuntu 24.04 dropped the awscli v1 apt package. Install v2 from
# the official AWS bundle.
curl -fsSL 'https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip' -o /tmp/awscliv2.zip
unzip -oq /tmp/awscliv2.zip -d /tmp
/tmp/aws/install --update

# Discover the instance's public IPv4. coturn needs the literal
# EIP for STUN responses; the metadata service is the source of
# truth.
TOKEN="$(curl -fsS -X PUT 'http://169.254.169.254/latest/api/token' \
  -H 'X-aws-ec2-metadata-token-ttl-seconds: 60')"
EXTERNAL_IP="$(curl -fsS -H "X-aws-ec2-metadata-token: ${TOKEN}" \
  http://169.254.169.254/latest/meta-data/public-ipv4)"

# Pull the three shared secrets the configs need. All three are
# JSON `{"secret": "..."}` blobs auto-generated by CDK
# SecretStringGenerator at first deploy.
get_secret_field() {
  local secret_id="$1"
  local field="$2"
  aws --region '@@AWS_REGION@@' secretsmanager get-secret-value \
    --secret-id "${secret_id}" --query SecretString --output text \
    | jq -r ".\"${field}\""
}
TURN_SHARED_SECRET="$(get_secret_field '@@TURN_SHARED_SECRET_NAME@@' secret)"
LIVEKIT_API_KEY="$(get_secret_field '@@LIVEKIT_API_KEY_SECRET_NAME@@' secret)"
LIVEKIT_API_SECRET="$(get_secret_field '@@LIVEKIT_API_SECRET_SECRET_NAME@@' secret)"

# Pull the asset bundle (turnserver.conf.tmpl, livekit.yaml.tmpl)
# uploaded by CDK as an s3_assets.Asset.
mkdir -p /opt/turn-assets
aws --region '@@AWS_REGION@@' s3 cp \
  '@@ASSET_S3_URI@@' /tmp/turn-assets.zip
unzip -o /tmp/turn-assets.zip -d /opt/turn-assets

# Install livekit-server. No apt package; the upstream release
# ships a single static Linux/amd64 binary.
curl -fsSL \
  "https://github.com/livekit/livekit/releases/download/v@@LIVEKIT_VERSION@@/livekit_@@LIVEKIT_VERSION@@_linux_amd64.tar.gz" \
  -o /tmp/livekit.tar.gz
mkdir -p /opt/livekit
tar -xzf /tmp/livekit.tar.gz -C /opt/livekit
install -m 0755 /opt/livekit/livekit-server /usr/local/bin/livekit-server
useradd --system --home /nonexistent --no-create-home \
  --shell /usr/sbin/nologin livekit || true

# Issue the multi-SAN TLS cert via DNS-01 (Route53). Instance
# role permits route53:ChangeResourceRecordSets on the public
# zone, so certbot's dns-route53 plugin works without any creds.
certbot certonly \
  --non-interactive --agree-tos \
  --email "admin@@@PUBLIC_DOMAIN@@" \
  --dns-route53 \
  --dns-route53-propagation-seconds 30 \
  -d '@@TURN_FQDN@@' -d '@@LIVEKIT_FQDN@@'

CERT_DIR="/etc/letsencrypt/live/@@TURN_FQDN@@"
TLS_CERT_PATH="${CERT_DIR}/fullchain.pem"
TLS_KEY_PATH="${CERT_DIR}/privkey.pem"

# Both coturn and livekit need to read the privkey. Create a
# shared group, add both service users, and re-permission the
# live + archive trees so renewals don't reset perms.
groupadd --system tls-readers || true
usermod -a -G tls-readers turnserver
usermod -a -G tls-readers livekit
chgrp -R tls-readers /etc/letsencrypt/live /etc/letsencrypt/archive
chmod -R g+rX /etc/letsencrypt/live /etc/letsencrypt/archive
chmod g+rx /etc/letsencrypt

# Render the inner configs. __KEY__ markers; substituted with
# either Python-rendered constants or shell-discovered values.
render() {
  local src="$1"
  local dst="$2"
  local tmp
  tmp="$(mktemp)"
  cp "${src}" "${tmp}"
  sed -i \
    -e "s|__EXTERNAL_IP__|${EXTERNAL_IP}|g" \
    -e "s|__TURN_SHARED_SECRET__|${TURN_SHARED_SECRET}|g" \
    -e "s|__LIVEKIT_API_KEY__|${LIVEKIT_API_KEY}|g" \
    -e "s|__LIVEKIT_API_SECRET__|${LIVEKIT_API_SECRET}|g" \
    -e 's|__RELAY_MIN_PORT__|@@RELAY_MIN_PORT@@|g' \
    -e 's|__RELAY_MAX_PORT__|@@RELAY_MAX_PORT@@|g' \
    -e 's|__PUBLIC_DOMAIN__|@@PUBLIC_DOMAIN@@|g' \
    -e 's|__TURN_FQDN__|@@TURN_FQDN@@|g' \
    -e 's|__LIVEKIT_FQDN__|@@LIVEKIT_FQDN@@|g' \
    -e "s|__TLS_CERT_PATH__|${TLS_CERT_PATH}|g" \
    -e "s|__TLS_KEY_PATH__|${TLS_KEY_PATH}|g" \
    "${tmp}"
  install -m 0640 -o root -g tls-readers "${tmp}" "${dst}"
  rm -f "${tmp}"
}
render /opt/turn-assets/turnserver.conf.tmpl /etc/turnserver.conf
mkdir -p /etc/livekit
render /opt/turn-assets/livekit.yaml.tmpl /etc/livekit/livekit.yaml
# nginx vhost (root-readable; nginx runs as www-data which is
# also added to tls-readers below for cert access).
render /opt/turn-assets/nginx-livekit.conf.tmpl /etc/nginx/sites-available/livekit
ln -sf /etc/nginx/sites-available/livekit /etc/nginx/sites-enabled/livekit
rm -f /etc/nginx/sites-enabled/default
usermod -a -G tls-readers www-data

# Enable coturn (Ubuntu's package ships a disabled-by-default
# systemd unit guarded by /etc/default/coturn).
sed -i 's/^#TURNSERVER_ENABLED=1/TURNSERVER_ENABLED=1/' /etc/default/coturn
systemctl enable --now coturn

# livekit-server systemd unit + start.
cat >/etc/systemd/system/livekit-server.service <<'EOF'
[Unit]
Description=LiveKit SFU
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=livekit
Group=tls-readers
ExecStart=/usr/local/bin/livekit-server --config /etc/livekit/livekit.yaml
Restart=on-failure
RestartSec=5
LimitNOFILE=65536
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log

[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl enable --now livekit-server
systemctl enable --now nginx
systemctl reload nginx

# Renewal deploy-hook: re-permission the renewed material and
# reload both services. certbot's systemd timer (shipped by the
# package) calls `certbot renew` twice daily; the deploy-hook
# only fires when a cert was actually issued.
mkdir -p /etc/letsencrypt/renewal-hooks/deploy
cat >/etc/letsencrypt/renewal-hooks/deploy/coturn-livekit.sh <<'EOF'
#!/bin/bash
set -euo pipefail
chgrp -R tls-readers /etc/letsencrypt/live /etc/letsencrypt/archive
chmod -R g+rX /etc/letsencrypt/live /etc/letsencrypt/archive
systemctl reload coturn || systemctl restart coturn
systemctl reload nginx || systemctl restart nginx
systemctl restart livekit-server
EOF
chmod 0755 /etc/letsencrypt/renewal-hooks/deploy/coturn-livekit.sh

echo "turn user-data: coturn + livekit-server up; cert at ${CERT_DIR}"
